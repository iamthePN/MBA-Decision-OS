POSTGRES_DB=mba_decision_os
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql://postgres:change-this-db-password@postgres:5432/mba_decision_os?schema=public
NEXTAUTH_URL=http://YOUR_EC2_PUBLIC_DNS
NEXTAUTH_SECRET=replace-with-a-long-random-secret
APP_NAME=MBA Decision OS
APP_URL=http://YOUR_EC2_PUBLIC_DNS
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@mbadecisionos.local
ENABLE_FILE_STORAGE=false
STORAGE_PROVIDER=local
ENABLE_ANALYTICS=false
ANALYTICS_PROVIDER=console
ENABLE_AI_SUMMARIES=false
AI_PROVIDER=mock
